@"
# LLM Configuration - Choose one: anthropic, groq, or ollama
LLM_PROVIDER=groq
ANTHROPIC_API_KEY=sk-...
GROQ_API_KEY=gsk_...
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/maintenance_rag

# Vector search
VECTOR_DB_TYPE=pgvector
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# Retrieval
TOP_K_RETRIEVAL=50
TOP_K_RERANK=5
BM25_WEIGHT=0.5
DENSE_WEIGHT=0.5

# Reranking
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BATCH_SIZE=32

# Evaluation
RAGAS_BATCH_SIZE=16

# AWS 
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ECR_REGISTRY=
@ | Out-File -FilePath ".env.example" -Encoding UTF8
